!.env.example

# Dependencies
node_modules/

# Build output
dist/
build/
out/
.vite/

# AFK orchestrator run artifacts — never committed
.orchestrator/

# ADO mode (.factory.yml declares `ado:`): Spec/Plan docs are transient local
# artifacts written by /brainstorming and /writing-plans. /publish-feature
# pushes their exact contents into the ADO Feature's Description and
# Implementation Plan fields — ADO, not git, is the durable copy on this repo.
# Ignored (not just left untracked) so generic git-hygiene tooling doesn't
# flag them as forgotten uncommitted work.
docs/superpowers/specs/
docs/superpowers/plans/
